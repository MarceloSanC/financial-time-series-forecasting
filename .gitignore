# ======================================================
# Ambientes virtuais
# ======================================================
.venv/
.venv_nlp/
env/
ENV/

# ======================================================
# Python caches / compilados
# ======================================================
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
.ipynb_checkpoints/

# ======================================================
# Build / packaging
# ======================================================
build/
dist/
*.egg
*.egg-info/
*.whl
*.deb

# ======================================================
# ===================== DADOS ==========================
# ======================================================
# Todos os dados são gerados ou dependem de fontes externas
# NÃO devem ser versionados

data/**

# Exceção opcional: manter estrutura vazia
!data/**/.gitkeep

# ======================================================
# LaTeX (TCC em text/)
# ======================================================
# Versionar fontes em text/ (tex, bib, imagens), ignorar apenas gerados
*.aux
*.bbl
*.bcf
*.blg
*.fdb_latexmk
*.fls
*.idx
*.ilg
*.ind
*.lof
*.lot
*.nlo
*.nls
*.run.xml
*.synctex.gz
*.toc
*.xdv

# PDF final do LaTeX (opcional manter ignorado)
text/Main.pdf

# ======================================================
# Notebooks (exploratórios / não determinísticos)
# ======================================================
notebooks/**

# Se quiser versionar notebooks finais, remova a linha acima
# ou use exceções explícitas:
# !notebooks/final/**

# ======================================================
# Outputs / relatórios gerados
# ======================================================
output/
results/
reports/**

# ======================================================
# Logs
# ======================================================
*.log
*.out
lightning_logs/

# ======================================================
# Configurações locais / segredos
# ======================================================
.env
.env.*
config/local.yaml
.codex
codex/

# ======================================================
# IDEs / Editores
# ======================================================
.vscode/
.idea/
*.swp
*.swo

# ======================================================
# Sistema operacional
# ======================================================
.DS_Store
Thumbs.db

# ======================================================
# Coverage / testes
# ======================================================
.coverage
.coverage.*
htmlcov/
pytest_cache/
